# wechat-article 环境变量样例
# 用法：复制为 .env（去掉 .example），填好真实值，不要 commit

# =========================
# LLM (Phase 0 单线写作)
# =========================
DEEPSEEK_API_KEY=sk-CHANGE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
ARTICLE_WRITER_MODEL=deepseek-v4-flash
ARTICLE_WRITER_MAX_TOKENS=8000
ARTICLE_WRITER_TIMEOUT=240
ARTICLE_WRITER_TEMPERATURE=0.7
# 大 PDF 抽取页数上限（防爆上下文）；留空=不限。也可在 jobs.yaml 的 job.extra.max_pages 按篇设
# PDF_MAX_PAGES=25

# =========================
# 微信公众号（多账户；token 按账户隔离）
# =========================
# 每条内容线在 inputs/lines/{line}.yaml 的 extra.wechat_account 指定账户名，
# 这里按账户名大写填凭据：WECHAT_{ACCOUNT}_APP_ID / _APP_SECRET / _THUMB_MEDIA_ID
# ⚠️ 公众号 API 要求调用方 IP 在该账户后台「设置与开发→基本配置→IP 白名单」里，
#    否则 access_token 报 errcode 40164（凭据对也调不通）。

# 免疫客（Solidex 线 → wechat_account: immune）
WECHAT_IMMUNE_APP_ID=wx-CHANGE_ME
WECHAT_IMMUNE_APP_SECRET=CHANGE_ME
WECHAT_IMMUNE_THUMB_MEDIA_ID=        # 封面永久素材 id（后台素材库上传后获取）

# AAV（AAV 线 → wechat_account: aav）
WECHAT_AAV_APP_ID=
WECHAT_AAV_APP_SECRET=
WECHAT_AAV_THUMB_MEDIA_ID=

# 通用回落（account=default；未配账户专属凭据时用）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
DEFAULT_THUMB_MEDIA_ID=

# 草稿作者署名（公众号文章「作者」字段，上限 8 字）。优先级：WECHAT_{ACCOUNT}_AUTHOR > DEFAULT_AUTHOR
WECHAT_IMMUNE_AUTHOR=毒仔 Gee     # 免疫客（Solidex 线）作者署名
WECHAT_AAV_AUTHOR=Ab妹 Abee      # AAV 线作者署名
DEFAULT_AUTHOR=TarMart

# =========================
# 数据库
# =========================
# 默认 SQLite 放 runtime/wechat_article.db；要换 MySQL 填这个
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/wechat_article

# 文章产物落盘根目录（默认 outputs/jobs）
# ARTICLE_CONTENT_DIR=outputs/jobs

# =========================
# 视觉模型（VLM 自动配图）
# =========================
# 渲染含图页 → VLM 读「图号 + 整图 bbox」→ 裁图按图号匹配正文 [图片:Figure N]。
# OpenAI 兼容接口。kimi-k2.6 是推理模型(需 temperature=1 + 充足 max_tokens)；
# 想省钱/更快可换 moonshot-v1-32k-vision-preview(纯视觉、非推理)。
VISION_API_KEY=
VISION_BASE_URL=https://api.moonshot.cn/v1
VISION_MODEL=kimi-k2.6
# VISION_FIGURES_ENABLED=1     # 设 0 关闭 VLM 抽图（回落版式启发式）
# VISION_MAX_TOKENS=2048       # 推理模型要留足，否则答案被截空
# VISION_TIMEOUT=180

# =========================
# 日志
# =========================
LOG_LEVEL=INFO
